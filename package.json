{
  "name": "ssg-starter",
  "version": "1.0.0",
  "description": "SSG Starter - Eleventy static site generator with theme system, GSAP animations, and Sveltia CMS",
  "main": "index.js",
  "scripts": {
    "start": "npm run start:proxy & npm run watch:scss & npm run watch:js & npm run start:eleventy",
    "build": "npm run clean && npm run build:blog-images && npm run build:scss && NODE_ENV=production npm run build:eleventy && npm run build:assets",
    "build:scss": "sass src/assets/css/main.scss public/assets/css/style.css --no-source-map --style=compressed && postcss public/assets/css/style.css -o public/assets/css/style.css",
    "watch:scss": "sass --watch src/assets/css/main.scss:public/assets/css/style.css",
    "postcss": "postcss public/assets/css/style.css -o public/assets/css/style.css",
    "watch:js": "nodemon --watch src/assets/js --ext js --exec \"npm run build:assets\"",
    "start:eleventy": "eleventy --serve",
    "build:eleventy": "eleventy",
    "start:proxy": "netlify-cms-proxy-server",
    "clean": "rm -rf public/*",
    "build:assets": "node build-assets.js",
    "build:blog-images": "node build-blog-images.js",
    "setup": "node setup-site.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YOUR-USERNAME/ssg-starter.git"
  },
  "keywords": [
    "eleventy",
    "static-site-generator",
    "ssg",
    "template",
    "starter-kit",
    "sveltia-cms",
    "gsap",
    "sass",
    "business-website"
  ],
  "author": "Your Name",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/YOUR-USERNAME/ssg-starter/issues"
  },
  "homepage": "https://github.com/YOUR-USERNAME/ssg-starter#readme",
  "devDependencies": {
    "@11ty/eleventy": "^3.1.0",
    "@11ty/eleventy-navigation": "^0.3.5",
    "autoprefixer": "^10.4.22",
    "chalk": "^4.1.2",
    "critical": "^5.1.2",
    "esbuild": "^0.25.5",
    "html-minifier-terser": "^7.2.0",
    "inquirer": "^8.2.6",
    "js-yaml": "^4.1.0",
    "netlify-cms-proxy-server": "^1.3.24",
    "nodemon": "^3.1.10",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.1",
    "sass": "^1.89.0",
    "sharp": "^0.34.5"
  },
  "dependencies": {
    "@11ty/eleventy-img": "^6.0.4",
    "gsap": "^3.13.0",
    "masonry-layout": "^4.2.2",
    "photoswipe": "^5.4.4"
  },
  "browserslist": [
    "last 2 years",
    "> 0.5%",
    "not dead"
  ]
}